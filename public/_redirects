# Canonical: www -> apex (one site only — avoids split cache / broken CSS)
https://www.acopay.net/*   https://acopay.net/:splat   301
http://www.acopay.net/*    https://acopay.net/:splat   301
http://acopay.net/*        https://acopay.net/:splat   301

# Missing CSS/JS must 404 — do not return index.html as stylesheet
/assets/*.css   /404.html   404
/assets/*.js    /404.html   404
/assets/*.map   /404.html   404

# React Router SPA fallback
/*    /index.html   200
