# HTML: always revalidate after each deploy (avoid stale HTML → dead CSS hashes)
/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# Hashed Vite assets: long cache (safe — filename changes every build)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff
