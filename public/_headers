# Always revalidate HTML after each deploy
/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/sitemap.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=3600

/site.webmanifest
  Cache-Control: public, max-age=86400

# Vite hashed build assets
/assets/index-*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Brand assets — allow refresh (not immutable)
/assets/logo.png
  Cache-Control: public, max-age=86400
  X-Content-Type-Options: nosniff

/assets/logo-solid.png
  Cache-Control: public, max-age=3600
  X-Content-Type-Options: nosniff

/assets/logo-token.png
  Cache-Control: public, max-age=3600
  X-Content-Type-Options: nosniff

/assets/logo-round.png
  Cache-Control: public, max-age=3600
  X-Content-Type-Options: nosniff

/assets/favicon.png
  Cache-Control: public, max-age=86400
  X-Content-Type-Options: nosniff

# Social preview image
/assets/og-image.png
  Cache-Control: public, max-age=86400
  X-Content-Type-Options: nosniff

/assets/og-image.jpg
  Cache-Control: public, max-age=86400
  X-Content-Type-Options: nosniff

# Other public assets default
/assets/*
  Cache-Control: public, max-age=86400
  X-Content-Type-Options: nosniff
