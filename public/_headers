# Always revalidate HTML after each deploy
/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/sitemap.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=3600

/site.webmanifest
  Cache-Control: public, max-age=86400

# Hashed Vite assets — long cache (filename changes every build)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Social preview image — shorter cache so OG updates propagate
/assets/og-image.png
  Cache-Control: public, max-age=86400
  X-Content-Type-Options: nosniff

/assets/og-image.jpg
  Cache-Control: public, max-age=86400
  X-Content-Type-Options: nosniff
